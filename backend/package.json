    "@nestjs/platform-express": "^10.4.6",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.2.1",
    "@sideway/formula": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "bson": "^6.10.4",
    "bullmq": "^5.79.2",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.5",
